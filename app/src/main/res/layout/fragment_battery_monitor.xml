<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stability Monitor"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/currentBatteryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current: --%"
                    android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                    android:textColor="?attr/colorPrimary"
                    android:layout_gravity="center_horizontal"/>

                <TextView
                    android:id="@+id/currentRssiText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RSSI: -- dBm"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/currentGlitchesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Glitches: 0 (Phone buffer)"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="#E53935"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/targetDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device: None"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Log Interval (seconds)"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/batteryIntervalInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="60"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swEnableAudioMonitor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Audio Quality Monitor"
                    android:checked="true"
                    android:layout_marginBottom="4dp"/>

                <CheckBox
                    android:id="@+id/cbSilentMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Silent Mode (for Spotify/Music)"
                    android:checked="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buffer Strategy:"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/bufferStrategySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnStartBatteryLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start Monitoring"/>

                <Button
                    android:id="@+id/btnStopBatteryLog"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stop Monitoring"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="400dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stability Log"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"/>
                    <Button
                        android:id="@+id/btnClearBatteryLog"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Clear"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/batteryHistoryText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#000000"
                    android:padding="8dp"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false"
                    android:scrollbarStyle="insideOverlay"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
