<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Media Control Stress"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/targetDeviceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target: None"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/currentStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/design_default_color_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/media_stress_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/design_default_color_primary"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="#E3F2FD"/>

        <!-- Manual Controls Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual AVRCP Controls"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/openSpotifyButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/open_spotify"
                    app:icon="@android:drawable/ic_menu_slideshow" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3">

                    <Button android:id="@+id/prevButton" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Prev" android:layout_margin="2dp"/>
                    <Button android:id="@+id/playPauseButton" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Play/Pause" android:layout_margin="2dp"/>
                    <Button android:id="@+id/nextButton" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Next" android:layout_margin="2dp"/>

                    <Button android:id="@+id/volDownButton" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Vol -" android:layout_margin="2dp"/>
                    <Button android:id="@+id/stopButton" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Stop" android:layout_margin="2dp"/>
                    <Button android:id="@+id/volUpButton" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Vol +" android:layout_margin="2dp"/>
                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Automation Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Automation Stress Settings"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Volume Cycle Stress"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/design_default_color_primary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/vol_interval_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/volIntervalInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="1000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/min_pct_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/minVolInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="20"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:hint="@string/max_pct_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/maxVolInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="70"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/startVolCycleButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Start Volume Cycle"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Rapid Commands Stress"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/design_default_color_primary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/base_interval_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rapidIntervalInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="1000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/random_range_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/randomRangeInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="500"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:flexWrap="wrap"
                    app:alignItems="stretch"
                    app:alignContent="stretch" >
                    <CheckBox android:id="@+id/cbPlayPause" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Play/Pause" android:checked="true"/>
                    <CheckBox android:id="@+id/cbNext" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Next" android:layout_marginStart="8dp"/>
                    <CheckBox android:id="@+id/cbPrev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prev" android:layout_marginStart="8dp"/>
                    <CheckBox android:id="@+id/cbStop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stop" android:layout_marginStart="8dp"/>
                </com.google.android.flexbox.FlexboxLayout>

                <Button
                    android:id="@+id/startRapidPlayButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Start Rapid Commands"/>

                <Button
                    android:id="@+id/stopAutoButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Stop Automation"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Log Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test Log"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"/>
                    <Button
                        android:id="@+id/clearLogButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Clear"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/mediaLogText"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#000000"
                    android:padding="8dp"
                    android:text="Log initialized...\n"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:scrollbars="vertical"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
